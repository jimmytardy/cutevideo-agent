# IA
ANTHROPIC_API_KEY=...


# Base de données
# Dev local (hors Docker) — ports mappés par docker-compose :
DATABASE_URL=postgresql+asyncpg://cutevideo:cutevideo@localhost:5433/cutevideo
REDIS_URL=redis://localhost:6380

# Sources médias libres
UNSPLASH_ACCESS_KEY=...
PEXELS_API_KEY=...
PIXABAY_API_KEY=...
FREESOUND_API_KEY=...
EUROPEANA_API_KEY=...

# YouTube (compte Google partagé — chaînes Brand en DB)
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/channels/youtube/oauth/callback
API_BASE_URL=http://localhost:8000

# Instagram (token global — page_id par chaîne en DB)
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_PAGE_ID=...

# Composio (TikTok : un compte OAuth par chaîne)
COMPOSIO_API_KEY=...

# Runway (génération vidéo IA — budget mensuel par chaîne configurable)
RUNWAY_API_KEY=

# Stockage S3 (recommandé en prod)
STORAGE_BACKEND=s3
S3_BUCKET=your-bucket-name
S3_REGION=eu-west-3
S3_KEY_PREFIX=cutevideo
S3_PRESIGN_TTL_SECONDS=3600
S3_ENDPOINT_URL=
S3_DELETE_LOCAL_AFTER_UPLOAD=true
STORAGE_RETENTION_DAYS=30
S3_MAX_STORAGE_BYTES=10737418240
S3_STORAGE_BUFFER_BYTES=524288000
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Dev local sans S3 (TikTok via endpoint temp — nécessite URL publique)
# STORAGE_BACKEND=local
# MEDIA_PUBLIC_BASE_URL=http://localhost:8000

# TTS Azure Neural (production) — edge-tts en fallback si absent
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
TTS_ENGINE=azure

# Gemini TTS (optionnel) — utilise GOOGLE_GEMINI_API_KEY déjà définie ci-dessous.
# Configurer apply_to dans data/agent_config.json ou par chaîne : off | shorts | long | both

# Images IA fallback (Flux via fal.ai + Google Imagen 3 via Vertex AI)
FAL_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Gemini API key (AI Studio) — recherche, scoring média, et TTS Gemini Flash (optionnel)
GOOGLE_GEMINI_API_KEY=
GCP_PROJECT_ID=
GCP_LOCATION=europe-west1

# Scheduler intégré à l'API
SCHEDULER_ENABLED=true

# Config pipeline
WHISPER_MODEL=large-v3
MAX_CRITIC_ITERATIONS=3
MIN_CRITIC_SCORE=70
MIN_IMAGE_DURATION_S=4
CONFIG_PATH=./data/agent_config.json

# Docker local (docker compose up -d app-dev) + docker-deploy.sh en prod
PORT=3000
# En prod avec Tailscale : mettre l'IP Tailscale du VPS (tailscale ip -4)
# Laisser vide en dev local (expose sur toutes les interfaces)
APP_HOST=
INTERNAL_API_URL=http://127.0.0.1:8000
# En Docker dev (app-dev), SCHEDULER_ENABLED=false est forcé dans docker-compose.yml.
# Les pipelines sont exécutés par le service worker-dev (queue Redis).
# SCHEDULER_ENABLED=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# En Docker local, DATABASE_URL et REDIS_URL sont surchargés dans docker-compose.yml.
# Après un git pull contenant de nouvelles migrations Alembic :
#   docker compose restart app-dev worker-dev
# ou : docker compose run --rm --no-deps --entrypoint alembic app-dev upgrade head
# Pour OAuth depuis le dashboard Docker, utiliser l'URL externe du proxy Next :
# API_BASE_URL=http://localhost:3000
# YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/channels/youtube/oauth/callback

# Production VPS — déployer avec docker-deploy.sh (le script connecte aussi local-network)
DATABASE_URL=postgresql+asyncpg://cutevideo:MOT_DE_PASSE@shared-postgres:5432/cutevideo
